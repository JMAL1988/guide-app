default_platform(:ios)

platform :ios do
  desc "Upload to App Store Connect via Match"
  lane :appstore do
    # Set up App Store Connect API key
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_PRIVATE_KEY"],
      is_key_content_base64: false,
      duration: 1200,
      in_house: false
    )

    # Install certificates and provisioning profiles from Match
    match(
      type: "appstore",
      readonly: true,
      app_identifier: [
        "com.joostlaarakker.guide",
        "com.joostlaarakker.guide.watchkitapp",
        "com.joostlaarakker.guide.watchcontainer"
      ],
      api_key: api_key,
      git_basic_authorization: Base64.strict_encode64("JMAL1988:#{ENV["MATCH_GITHUB_TOKEN"]}")
    )

    # Update code signing settings for manual signing in all targets
    update_code_signing_settings(
      use_automatic_signing: false,
      team_id: "HZB9DA7TPR",
      code_sign_identity: "Apple Distribution",
      targets: ["Guide individual"],
      profile_name: "match AppStore com.joostlaarakker.guide",
      build_configurations: ["Release"]
    )

    update_code_signing_settings(
      use_automatic_signing: false,
      team_id: "HZB9DA7TPR",
      code_sign_identity: "Apple Distribution",
      targets: ["Guide Individual Watch Watch App"],
      profile_name: "match AppStore com.joostlaarakker.guide.watchkitapp",
      build_configurations: ["Release"]
    )

    update_code_signing_settings(
      use_automatic_signing: false,
      team_id: "HZB9DA7TPR",
      code_sign_identity: "Apple Distribution",
      targets: ["Guide Individual Watch"],
      profile_name: "match AppStore com.joostlaarakker.guide.watchcontainer",
      build_configurations: ["Release"]
    )

    # Build and archive
    gym(
      project: "Guide individual.xcodeproj",
      scheme: "Guide individual",
      configuration: "Release",
      export_method: "app-store",
      export_options: {
        teamID: "HZB9DA7TPR",
        method: "app-store",
        signingStyle: "manual",
        stripSwiftSymbols: true,
        uploadSymbols: true,
        provisioningProfiles: {
          "com.joostlaarakker.guide" => "match AppStore com.joostlaarakker.guide",
          "com.joostlaarakker.guide.watchkitapp" => "match AppStore com.joostlaarakker.guide.watchkitapp",
          "com.joostlaarakker.guide.watchcontainer" => "match AppStore com.joostlaarakker.guide.watchcontainer"
        }
      },
      output_directory: "/tmp/guide_build",
      output_name: "Guide",
      buildlog_path: "/tmp/gym_buildlog"
    )

    # Upload to App Store Connect
    upload_to_app_store(
      api_key: api_key,
      skip_metadata: true,
      skip_screenshots: true,
      force: true,
      submit_for_review: false,
      precheck_include_in_app_purchases: false,
      ipa: "/tmp/guide_build/Guide.ipa"
    )
  end
end
